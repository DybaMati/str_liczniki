# MySQL (skopiuj do .env i uzupełnij nazwę bazy)
# DATABASE_URL=mysql+pymysql://USER:HASLO@10.10.0.21:3306/NAZWA_BAZY?charset=utf8mb4

# SQLite (tylko demo lokalne: python -m app.init_demo_db)
# DATABASE_URL=sqlite:///./pv_demo.db

# ID liczników (opcjonalnie)
# LICZNIK_TOMEK_ID=7
# LICZNIK_LONIA_ID=8
# LICZNIK_HENIA_ID=9

# Opcjonalnie JSON nazw liczników: {"7":"Tomek L1","8":"Lonia L2","9":"Henia L3"}
# METER_LABELS_JSON=

# Nazwa w menu i w tytule kart (zamiast „PV / liczniki”)
# SITE_PUBLIC_NAME=Panel odczytów

# Dostęp tylko z podanych IP lub sieci (CIDR), po przecinku. Puste = wszyscy.
# Przykład: 127.0.0.1,192.168.1.0/24,10.10.0.50
# ALLOWED_CLIENT_IPS=
# Za nginx — ustaw True, wtedy pierwszy adres z X-Forwarded-For to klient
# TRUST_X_FORWARDED_FOR=false

# Strona odmowy (gdy IP spoza listy)
# DENIED_PAGE_TITLE=Wejście
# DENIED_PAGE_MESSAGE=Czego tutaj szukasz?? Ciekawość to pierwszy stopień do piekła...
